APP_NAME=Emotion Recognition System API
API_PREFIX=/api
DATABASE_URL=sqlite:///./database/emotion_system.db
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DEFAULT_FACE_WEIGHT=0.30
DEFAULT_VOICE_WEIGHT=0.40
DEFAULT_TEXT_WEIGHT=0.30
HF_TEXT_MODEL=j-hartmann/emotion-english-distilroberta-base
SB_VOICE_MODEL=speechbrain/emotion-recognition-wav2vec2-IEMOCAP
